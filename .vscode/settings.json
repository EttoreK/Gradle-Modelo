    "**/.project": true,
    "**/.settings": true,
    "**/bin": true,
    "**/.build": true
  },
  "gradle.nestedProjects": true,
  "gradle.debug": true,
  "java.compile.nullAnalysis.mode": "automatic",
  "java.configuration.runtimes": [
